# Knowledge base — both layers ignored (sensitive content), keep structure only
workspace/knowledge/**/*
!workspace/knowledge/**/
!workspace/knowledge/**/.gitkeep
!workspace/inbox/.gitkeep
!workspace/transcripts/.gitkeep
!workspace/archive/audio/.gitkeep
!workspace/archive/transcripts/.gitkeep

