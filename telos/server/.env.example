# telos LLM bridge の設定。コピーして `.env` を作り、`pnpm bridge` で起動する。
# どちらの利用形態を使うかを TELOS_PROVIDER で選ぶ。

# ───────────────────────────────────────────────
# 形態1: claude-cli（既定）— サブスクリプションをそのまま使う
#   ローカルにインストール済みの `claude` を `claude -p` で呼ぶ。
#   Claude Pro / Max / Team の契約があれば API キーは不要。
# ───────────────────────────────────────────────
TELOS_PROVIDER=claude-cli
# TELOS_CLAUDE_BIN=claude          # claude 実行ファイルのパス（PATH が通っていれば不要）
# TELOS_CLAUDE_MODEL=              # 空ならアカウント既定モデル

# ───────────────────────────────────────────────
# 形態2: litellm — OpenAI 互換エンドポイントに API キーで転送
#   LiteLLM proxy / Anthropic / OpenAI など。トークン課金。
# ───────────────────────────────────────────────
# TELOS_PROVIDER=litellm
# TELOS_LLM_BASE_URL=http://localhost:4000
# TELOS_LLM_API_KEY=sk-...
# TELOS_LLM_MODEL=claude-sonnet-4-6

# 共通
# TELOS_BRIDGE_PORT=8787
# TELOS_TIMEOUT_MS=120000
