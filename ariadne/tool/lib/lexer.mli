(** クリーン化済みソース（コメント/文字列を除いたもの）を、メトリクス計測に
    必要な最小限のトークン列に変換する軽量字句解析器。

    完全な構文解析は行わない。複雑度メトリクスが必要とする
    「分岐キーワード・論理演算子・三項・波括弧の対応・関数の境界」だけを拾う。 *)

type token =
  | Word of string  (** 識別子またはキーワード *)
  | LBrace          (** [{] *)
  | RBrace          (** [}] *)
  | LParen          (** [(] *)
  | RParen          (** [)] *)
  | Semi            (** [;] *)
  | Question        (** 三項演算子の [?]（[?.] [??] 省略可能 [?:] は除外済み） *)
  | And             (** [&&] *)
  | Or              (** [||] *)
  | Nullish         (** [??] *)
  | Arrow           (** [=>] *)

(** [tokenize cleaned] はクリーン化済みソースをトークン列に変換する。
    上記以外の文字（数値・演算子・コロン等）はトークンを生成しない。 *)
val tokenize : string -> token list
