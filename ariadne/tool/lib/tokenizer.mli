(** ソースコードを「コード/ コメント / 文字列 / 空白」に分類しながら走査する
    手書きの字句スキャナ。

    目的は 2 つ:
    - メトリクス計測のための「クリーン化したソース」を作る
      （文字列とコメントの中身を空白に置き換え、[if] などのキーワードが
      文字列・コメント内で誤カウントされないようにする）
    - LOC 計測のための行分類（コード行 / コメント行 / 空行） *)

(** 1 行を何として数えるか。

    優先順位は code > comment > blank。
    つまり 1 行にコードとコメントが混在していれば [Code] に分類する。 *)
type line_kind =
  | Code
  | Comment
  | Blank

type t = {
  cleaned : string;
      (** 文字列リテラルの中身とコメントを空白に置換したソース。
          改行は保持されるので行数・オフセットは原文と一致する。 *)
  line_kinds : line_kind list;  (** 各行の分類（先頭行から順に） *)
}

(** [scan src] は TypeScript / JavaScript ソース [src] を 1 パスで走査し、
    クリーン化済みソースと行分類を返す。

    v0 の既知の制限:
    - テンプレートリテラル [`...`] の中の [${ ... }] も文字列として扱う
      （埋め込み式の中の分岐は数えない）。
    - 正規表現リテラルは扱わない（[/] は除算として扱う）。 *)
val scan : string -> t
